{
  "$schema": "https://biomejs.dev/schemas/2.4.4/schema.json",
  "plugins": [
    "node_modules/biome-plugin-no-type-assertion/no-type-assertion.grit",
    "./plugins/no-grouped-export.grit",
    "./plugins/no-interface.grit",
    "./plugins/one-export-per-file.grit"
  ],
  "files": {
    "includes": ["src/**"]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              ":BLANK_LINE:",
              ":PACKAGE:",
              ":BLANK_LINE:",
              ":PATH:"
            ]
          }
        }
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 90
  },
  "linter": {
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": {
          "level": "error",
          "options": { "maxAllowedComplexity": 15 }
        },
        "useLiteralKeys": "off"
      },
      "correctness": {
        "noUnusedImports": {
          "level": "error",
          "fix": "safe"
        }
      },
      "style": {
        "noNonNullAssertion": "error",
        "noDefaultExport": "error",
        "useBlockStatements": "error",
        "noNestedTernary": "error",
        "useDefaultSwitchClause": "error",
        "useImportType": "error"
      },
      "performance": {
        "noBarrelFile": "error",
        "noReExportAll": "error"
      }
    }
  }
}
